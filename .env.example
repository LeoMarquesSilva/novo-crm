NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
RD_CRM_TOKEN=
RD_WEBHOOK_SECRET=
# Segredo para cron (GET/POST /api/cron/rd-full-import). Na Vercel, defina o mesmo em CRON_SECRET do projeto.
CRON_SECRET=
VIOS_API_KEY=
D4SIGN_TOKEN=
# Opcional se a conta tiver cryptKey ativada
D4SIGN_CRYPT_KEY=
# Produção: https://secure.d4sign.com.br/api/v1 | Sandbox: https://sandbox.d4sign.com.br/api/v1
D4SIGN_API_BASE_URL=https://secure.d4sign.com.br/api/v1
# UUID do cofre (safe) onde o upload é permitido — menu Dev API na D4Sign
D4SIGN_SAFE_UUID=
# URL pública do CRM (webhook D4Sign, OAuth Outlook, links absolutos)
NEXT_PUBLIC_APP_URL=
# Polling de assinaturas no kanban: só necessário em dev (webhook não alcança localhost).
# Produção: omitir ou false — atualização via webhook D4Sign + Realtime Supabase (sem gastar quota).
# NEXT_PUBLIC_D4SIGN_KANBAN_POLLING=false
# Secret gerada em Dev API → "Gerar Secret Key MAC" (validação Content-Hmac no webhook)
D4SIGN_WEBHOOK_HMAC_SECRET=
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
# Nome da instância na Evolution API. No fluxo legado do N8N era "BP".
EVOLUTION_INSTANCE=
# Microsoft Graph — app registration (client credentials), permissão de aplicativo p.ex. Sites.ReadWrite.All
MICROSOFT_TENANT_ID=
SHAREPOINT_CLIENT_ID=
SHAREPOINT_CLIENT_SECRET=
# Site no formato Graph: host.sharepoint.com,{siteCollectionId},{siteId}
SHAREPOINT_SITE_ID=
SHAREPOINT_AGENDAMENTOS_LIST_ID=
# Protege POST /api/integrations/sharepoint/agendamentos
SHAREPOINT_INTEGRATION_SECRET=
